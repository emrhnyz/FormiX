# Deployer wallet (testnet only — never commit a real key)
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# CoFHE supported testnets — public RPCs work; optional Alchemy/Infura URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Default deploy target: base-sepolia | eth-sepolia | arb-sepolia
DEPLOY_NETWORK=base-sepolia
